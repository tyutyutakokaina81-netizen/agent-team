#!/bin/zsh
# setup — 初回セットアップ（1回だけ実行）
# 使い方（ターミナルに手入力）: zsh setup
REPO="$HOME/agent-team"
cd "$REPO"

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  セットアップ"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# 最新コード取得
echo "\n[1] 最新コード..."
git fetch origin claude/add-claude-documentation-Wipf0 --quiet
git reset --hard origin/claude/add-claude-documentation-Wipf0 --quiet
git config pull.ff only
echo "  OK: $(git log --oneline -1)"

# ライブラリ
echo "\n[2] ライブラリ..."
pip3 install playwright browser-cookie3 requests Pillow numpy pyopenjtalk \
  --break-system-packages -q 2>/dev/null || \
pip3 install playwright browser-cookie3 requests Pillow numpy pyopenjtalk -q 2>/dev/null || true
python3 -m playwright install chromium 2>/dev/null || true
echo "  OK"

# 画像生成
echo "\n[3] キャラクター画像..."
mkdir -p CMO/assets/announcer
python3 make_placeholder_char.py 2>/dev/null || true

# LaunchAgent（朝9時・昼14時・夜20時）
echo "\n[4] 自動スケジュール..."
mkdir -p "$HOME/Library/LaunchAgents" logs

for hour in 9 14 20; do
  name="com.agent-team.h${hour}"
  plist="$HOME/Library/LaunchAgents/${name}.plist"
  cat > "$plist" << PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>${name}</string>
  <key>ProgramArguments</key><array>
    <string>/bin/zsh</string><string>${REPO}/now</string>
  </array>
  <key>StartCalendarInterval</key><dict>
    <key>Hour</key><integer>${hour}</integer>
    <key>Minute</key><integer>0</integer>
  </dict>
  <key>WorkingDirectory</key><string>${REPO}</string>
  <key>StandardOutPath</key><string>${REPO}/logs/auto_${hour}h.log</string>
  <key>StandardErrorPath</key><string>${REPO}/logs/auto_${hour}h_err.log</string>
  <key>RunAtLoad</key><false/>
</dict></plist>
PLIST
  launchctl unload "$plist" 2>/dev/null || true
  launchctl load "$plist" && echo "  OK: ${hour}:00 自動実行"
done

# Mac自動ウェイクアップ（蓋を閉じたままでも動くように）
echo "\n[5] 自動ウェイクアップ設定..."

# sudoers: pmset をパスワードなしで実行できるように
SUDOERS_FILE="/etc/sudoers.d/agent-team-pmset"
echo "%admin ALL=(ALL) NOPASSWD: /usr/bin/pmset" | sudo tee "$SUDOERS_FILE" > /dev/null && \
  sudo chmod 440 "$SUDOERS_FILE" && \
  echo "  OK: pmset パスワードなし設定" || \
  echo "  NG: sudoers設定失敗"

# 8:58 は pmset repeat で毎日固定ウェイク
sudo pmset repeat wakeorpoweron MTWRFSU 08:58:00 2>/dev/null && \
  echo "  OK: 08:58 毎日ウェイク" || \
  echo "  NG: pmset repeat 失敗"

# 13:58 / 19:58 は LaunchAgent が毎朝スケジュールする
WAKE_PLIST="$HOME/Library/LaunchAgents/com.agent-team.wakeup.plist"
cat > "$WAKE_PLIST" << 'PLIST'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.agent-team.wakeup</string>
  <key>ProgramArguments</key><array>
    <string>/bin/zsh</string>
    <string>/Users/apple/agent-team/schedule_wakeups.zsh</string>
  </array>
  <key>StartCalendarInterval</key><dict>
    <key>Hour</key><integer>8</integer>
    <key>Minute</key><integer>50</integer>
  </dict>
  <key>StandardOutPath</key><string>/Users/apple/agent-team/logs/wakeup.log</string>
  <key>StandardErrorPath</key><string>/Users/apple/agent-team/logs/wakeup_err.log</string>
</dict></plist>
PLIST
launchctl unload "$WAKE_PLIST" 2>/dev/null || true
launchctl load "$WAKE_PLIST" && echo "  OK: 08:50 ウェイク予約スクリプト登録（13:58 / 19:58）"

echo "\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  完了！"
echo ""
echo "  Chrome で以下にログインしてから:"
echo "    note.com"
echo "    x.com"
echo "    studio.youtube.com"
echo ""
echo "  その後: zsh now"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
