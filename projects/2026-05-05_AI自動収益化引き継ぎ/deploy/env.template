# ============ 基本設定 ============

# 投稿実行モード。1=投稿しない（テスト）、0=本番投稿
DRY_RUN=1

# ============ LLM API（任意・既定OFF推奨） ============
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_DAILY_BUDGET_JPY=100

# ============ Reddit（公式API） ============
# https://www.reddit.com/prefs/apps で「script」タイプのアプリを作成
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-auto:v1.0 by /u/yourname
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_SUBREDDIT=SlowLiving

# ============ note RSS（任意） ============
NOTE_RSS_URL=

# ============ iPhone 連携 API サーバー（任意） ============
# 32文字以上のランダム文字列を推奨。空ならサーバーは loopback（127.0.0.1）からのみ受付
# 生成例: openssl rand -hex 24
AI_AUTO_TOKEN=
AI_AUTO_PORT=8765
