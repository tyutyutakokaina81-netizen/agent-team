node_modules/
.DS_Store
*.log
.env
*.env.*

# local-only / generated
.claude/*
# 共有すべき hook と settings は許可（PDCA SessionStart hook など）
!.claude/hooks/
!.claude/settings.json
bin/
md/
ppt/
claude_copy.sh
claude_team_v0.txt

# 機密ファイル（請求書・契約書・個人情報）
CFO/outputs/*
CFO/research/*
CSO/outputs/*
CSO/research/*
# フォルダ構造維持のため .gitkeep は除外しない
!CFO/outputs/.gitkeep
!CFO/research/.gitkeep
!CSO/outputs/.gitkeep
!CSO/research/.gitkeep
# 雛形・テンプレ Markdown は許可（センシティブな実データを含まない）
!CFO/outputs/*.md
!CFO/research/*.md
!CSO/outputs/*.md
!CSO/research/*.md
# 実請求書・実契約書・実取引データはサブフォルダで除外
CFO/outputs/_invoices/
CFO/outputs/_contracts/
CFO/outputs/_revenue_data/
CFO/research/_invoices/
CFO/research/_contracts/
CFO/research/_revenue_data/
CSO/outputs/_clients/
CSO/research/_clients/
*_actual.pdf
*_signed.pdf
*_secret*
*_confidential*
*_機密*
*_秘密*

# 柱D：納品前成果物・セッション情報
projects/*/D_エクセル入力スクレイピング/outputs/*
projects/*/D_エクセル入力スクレイピング/.sessions/*

# 個人情報・センシティブ情報の追加防衛線
*.csv
*.xlsx
*.numbers
*_personal*
*_private*
*_顧客*
*_取引先*
.cursor/
.vscode/settings.json
*.pem
*.key
**/credentials*
**/api_keys*
**/.aws/
**/.ssh/

# note 公開キット（コピペ即公開用 .txt は git に乗せない）
CMO/outputs/_publish_ready/

# 納品形式変換の出力（クライアント納品物・機密扱い）
*_plain.txt
*_html.html
*_docs.md

# オーナー個人情報（日記・アイデア・参考資料）
context/diary/*
context/ideas/*
context/references/*
# フォルダ構造維持のため .gitkeep は除外しない
!context/diary/.gitkeep
!context/ideas/.gitkeep
!context/references/.gitkeep
