node_modules/
.DS_Store
*.log
.env
*.env.*

# local-only / generated
.claude/
bin/
md/
ppt/
claude_copy.sh
claude_team_v0.txt

# 機密ファイル（請求書・契約書・個人情報）
CFO/outputs/*
CFO/research/*
CSO/outputs/*
CSO/research/*
# フォルダ構造維持のため .gitkeep は除外しない
!CFO/outputs/.gitkeep
!CFO/research/.gitkeep
!CSO/outputs/.gitkeep
!CSO/research/.gitkeep
# 公開可能な CFO 文書（事業計画書・予測・方針等）は例外として commit 許可
# ファイル名末尾に "_public" を付けること
!CFO/outputs/*_public.md
!CFO/outputs/reports/
!CFO/outputs/reports/*.md
*_secret*
*_confidential*
*_機密*
*_秘密*

# 柱D：納品前成果物・セッション情報
projects/*/D_エクセル入力スクレイピング/outputs/*
projects/*/D_エクセル入力スクレイピング/.sessions/*

# オーナー個人情報（日記・アイデア・参考資料）
context/diary/*
context/ideas/*
context/references/*
# フォルダ構造維持のため .gitkeep は除外しない
!context/diary/.gitkeep
!context/ideas/.gitkeep
!context/references/.gitkeep
# 自律ループが参照する standing directive は例外的に commit する
# （*_directive.md のみ、他のアイデア類は引き続き local-only）
!context/ideas/*_directive.md
