#!/bin/zsh
# now — ワンコマンド公開スクリプト
# 使い方（ターミナルに手入力）: zsh now
REPO="$HOME/agent-team"
cd "$REPO"

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  高岡アイ 公開実行"
echo "  $(date '+%Y-%m-%d %H:%M')"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# 最新コードに確実に同期（fetch してから reset）
echo "\n[git] 最新コード取得..."
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "claude/add-claude-documentation-Wipf0")
git fetch origin "$BRANCH" --quiet
git reset --hard "origin/$BRANCH" --quiet
echo "  OK: $(git log --oneline -1)"

# ── X API セットアップ（未設定なら自動で案内・設定） ──────────
echo "\n[0] X API チェック..."
if [ ! -f "$REPO/.env" ] || ! grep -q "X_API_KEY=\"[^\"]\+\"" "$REPO/.env" 2>/dev/null; then
  echo "  ⚠️  X API 未設定 → セットアップを開始します"
  echo ""
  echo "  【必要なもの（5分・無料）】"
  echo "  1. https://developer.twitter.com を開く"
  echo "  2. 無料登録 → App作成 → Keys and Tokens"
  echo "  3. 4つのキーをコピー"
  echo ""
  read "ans?  今すぐセットアップしますか？ [y/N]: "
  if [[ "$ans" == "y" || "$ans" == "Y" ]]; then
    bash "$REPO/setup_x_api.sh"
  else
    echo "  スキップ（次回 zsh now で再案内）"
  fi
else
  echo "  ✅ X API 設定済み"
fi

# note 公開
echo "\n[1] note 公開..."
python3 auto_note_publish.py || echo "  NG: note未ログイン？"

# X 投稿
echo "\n[2] X 投稿..."
python3 auto_x_post.py || echo "  NG: X未ログイン？"

# YouTube アップロード
echo "\n[3] YouTube アップロード..."
python3 auto_youtube_upload.py || echo "  NG: YouTube未ログイン？"

# 追加処理
echo "\n[4] アフィリエイト・横断変換..."
python3 auto_affiliate.py 2>/dev/null || true
python3 auto_repurpose.py 2>/dev/null || true

# 案件全自動サーチ＆応募（Playwright）
echo "\n[5] 案件自動応募..."
python3 auto_job_apply.py || echo "  NG: Chromeでcrowdworks.jp/lancers.jpにログインしているか確認"

echo "\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  完了 $(date '+%H:%M')"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
